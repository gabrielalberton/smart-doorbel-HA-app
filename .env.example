# Copy to .env and replace example values. Never commit .env.

# Android identity. Use your own reverse-DNS ID before distributing your build.
ANDROID_APPLICATION_ID=com.example.smartdoorbell
APP_DEEP_LINK_SCHEME=com.example.smartdoorbell
APP_NAME="Smart Doorbell"
ANDROID_VERSION_NAME=1.0.3
ANDROID_VERSION_CODE=18

# HTTPS origins returned by the server after first-run pairing.
PUBLIC_BASE_URL=https://doorbell.example.com
LOCAL_BASE_URL=https://doorbell.local.example.com
AUTH_HOST=auth.example.com

# Pairing accepts the user's password only long enough to verify this scrypt hash.
# Generate interactively with: cd server && node scripts/hash-pairing-password.js
PAIRING_PASSWORD_HASH=
PAIRING_MAX_ATTEMPTS=5
PAIRING_WINDOW_MS=600000

# Optional GitHub Releases updater. Public repository in owner/repository format.
GITHUB_RELEASE_REPO=your-github-user/smart-doorbel-HA-app
GITHUB_RELEASE_ASSET_SUFFIX=.apk

# Notification emitted by Home Assistant Companion and consumed by the app.
HOME_ASSISTANT_PACKAGE_PREFIX=io.homeassistant.companion.
DOORBELL_TRIGGER_TAG=smart_doorbell_trigger
DOORBELL_TRIGGER_CHANNEL=smart_doorbell_trigger
DOORBELL_NOTIFICATION_TITLE=Doorbell

# Backend / go2rtc / Frigate.
PORT=8080
FRIGATE_URL=http://frigate:5000
GO2RTC_URL=http://frigate:1984
PRIMARY_STREAM=doorbell_talk
PRIMARY_STREAM_OPTIONS=doorbell_talk,doorbell_low
SECONDARY_STREAM=
TALKBACK_TCP_STREAM=doorbell_talk
TALKBACK_UDP_STREAM=
TALK_LOCK_TTL_MS=15000

# Home Assistant webhook URLs are secrets. Keep them only in .env or a secret manager.
HA_WEBHOOK_URL=
ATTEND_WEBHOOK_URL=

# Optional server-hosted update fallback. GitHub Releases takes precedence when configured.
APP_UPDATE_VERSION=
APP_UPDATE_VERSION_CODE=0
APP_UPDATE_APK_PATH=
APP_UPDATE_SHA256=
